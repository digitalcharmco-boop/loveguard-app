# LoveGuard - Streamlit Cloud Secrets
# Copy this to .streamlit/secrets.toml for local dev (NEVER commit secrets.toml)
# On Streamlit Cloud, add these in Settings → Secrets

# OpenAI API Key
OPENAI_API_KEY = "sk-..."

# Stripe Payment Keys
STRIPE_SECRET_KEY = "sk_live_..."
STRIPE_PUBLISHABLE_KEY = "pk_live_..."

# App Settings
APP_ENV = "production"
DEBUG = "False"
GOOGLE_CLOUD_PROJECT = "instant-ranking-418806"
